# Jira Cloud Credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# Jira Project Configuration
JIRA_PROJECT_KEY=PROJ
JIRA_MAX_RESULTS=100

# Pod / Team Configuration
# Find POD_FIELD_ID in Jira: Settings > Issues > Custom Fields > your pod field > column ID
POD_FIELD_ID=customfield_10020
# POD_QA_MAP as JSON: maps pod names to QA owner names
POD_QA_MAP={"Platform":"Alice Chen","Growth":"Bob Martinez","Payments":"Carol Singh","Core API":"Dave Kim","Mobile":"Eve Okafor"}

# Anthropic API (for QA-7 chatbot)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Git Integration (optional)
GIT_REPO_PATH=/path/to/your/local/repo
# GitHub token — needed for PR diff fetching (dev-status integration)
# Create at: github.com > Settings > Developer Settings > Personal Access Tokens
# Required scopes: repo (read)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=org/repo-name
